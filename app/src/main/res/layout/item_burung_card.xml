<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/item_burung_card.xml -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardBurung"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/white"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Gambar / Emoji area -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:id="@+id/frameBirdImage">

            <!-- Background warna (hijau atau amber tergantung item) -->
            <View
                android:id="@+id/viewImgBg"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/g30ll" />

            <!-- Emoji placeholder burung -->
            <TextView
                android:id="@+id/tvBirdEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="🐦"
                android:textSize="40sp" />

            <!-- Badge kondisi (pojok kanan atas) -->
            <TextView
                android:id="@+id/tvBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="6dp"
                android:background="@drawable/bg_badge_green"
                android:text="Gacor"
                android:textColor="@color/white"
                android:textSize="9sp"
                android:textStyle="bold"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp" />

            <!-- Badge "Terjual" jika stok habis -->
            <View
                android:id="@+id/overlayTerjual"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#88000000"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvTerjual"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Terjual"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                android:visibility="gone" />

        </FrameLayout>

        <!-- Info burung -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:id="@+id/tvNamaBurung"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Murai Batu Medan"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/tvHarga"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Rp 2.500.000"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/g30"
                android:layout_marginBottom="2dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍"
                    android:textSize="9sp" />

                <TextView
                    android:id="@+id/tvLokasi"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Jakarta Selatan"
                    android:textSize="10sp"
                    android:textColor="@color/text_light"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginStart="2dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>