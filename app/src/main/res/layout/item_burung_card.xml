<!-- res/layout/item_burung_card.xml -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardBurung"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeWidth="0.5dp"
    app:strokeColor="@color/border">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Area gambar / emoji -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="100dp">

            <!-- Background warna (di-set via kode) -->
            <View
                android:id="@+id/viewImgBg"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Emoji burung -->
            <TextView
                android:id="@+id/tvBirdEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textSize="40sp"
                android:text="🐦" />

            <!-- Badge kondisi (kiri atas) -->
            <TextView
                android:id="@+id/tvBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_margin="6dp"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:background="@drawable/bg_badge_green"
                android:text="Anakan"
                android:textColor="@android:color/white"
                android:textSize="8sp"
                android:fontFamily="sans-serif-medium" />

            <!-- Overlay terjual (sembunyikan default) -->
            <View
                android:id="@+id/overlayTerjual"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#99000000"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvTerjual"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="TERJUAL"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:fontFamily="sans-serif-bold"
                android:visibility="gone" />

        </FrameLayout>

        <!-- Info teks -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="10dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tvNamaBurung"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Murai Batu Medan"
                android:textSize="11sp"
                android:textColor="@color/text_dark"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvLokasi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📍 Medan, SU"
                android:textSize="9sp"
                android:textColor="@color/text_light" />

            <TextView
                android:id="@+id/tvHarga"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Rp 3.500.000"
                android:textSize="12sp"
                android:textColor="@color/green_dark"
                android:fontFamily="sans-serif-medium" />

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>