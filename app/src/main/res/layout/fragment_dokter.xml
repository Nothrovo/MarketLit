<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_dokter.xml -->
<!-- Tab: Dokter (🩺) — KicauMart -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_surface">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/green_dark"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Dokter Burung"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium" />

            <ImageView
                android:id="@+id/btnNotifDokter"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_bell"
                app:tint="@color/white_80"
                android:contentDescription="Notifikasi" />
        </LinearLayout>
    </LinearLayout>

    <!-- Search + Filter Chips -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_surface"
        android:paddingHorizontal="14dp"
        android:paddingTop="12dp">

        <!-- Search field -->
        <LinearLayout
            android:id="@+id/searchBarDokter"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@drawable/bg_input_field_white"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="10dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_search"
                app:tint="@color/text_light"
                android:contentDescription="Cari" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cari dokter atau spesialisasi…"
                android:textSize="13sp"
                android:textColor="@color/text_light" />
        </LinearLayout>

        <!-- Filter Chips: Semua / Online / Rating -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="4dp">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupDokterFilter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:chipSpacingHorizontal="6dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipDokterSemua"
                    style="@style/KicauFilterChip"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Semua"
                    android:checked="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipDokterOnline"
                    style="@style/KicauFilterChip"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Online" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipDokterRating"
                    style="@style/KicauFilterChip"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Rating ★" />
            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- List Dokter -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDokterList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="14dp"
        android:paddingTop="8dp"
        android:paddingBottom="80dp"
        android:clipToPadding="false"
        tools:itemCount="3"
        tools:listitem="@layout/item_dokter_card" />

</LinearLayout>