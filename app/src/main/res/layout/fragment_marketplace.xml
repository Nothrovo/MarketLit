<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_market.xml -->
<!-- Tab: Market (🛍️) — KicauMart -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_surface">

    <!-- ── TOP BAR ── -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarMarket"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/green_dark"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbarMarket"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛍️ Marketplace"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium" />

            <!-- Icon group kanan: Bell + Cart -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:gap="14dp">

                <ImageView
                    android:id="@+id/btnNotifMarket"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_bell"
                    android:contentDescription="Notifikasi"
                    android:tint="@color/white_80" />

                <ImageView
                    android:id="@+id/btnCartMarket"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_cart"
                    android:contentDescription="Keranjang"
                    android:tint="@color/white_80" />
            </LinearLayout>
        </androidx.appcompat.widget.Toolbar>

        <!-- Search Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingTop="4dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:id="@+id/searchBarMarket"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@drawable/bg_searchbar"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:gap="8dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_search"
                    android:tint="@color/white_55"
                    android:contentDescription="Cari" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cari burung, kandang, pakan…"
                    android:textColor="@color/white_55"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ── SCROLLABLE CONTENT ── -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollMarket"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingBottom="72dp"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Filter Chips -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingHorizontal="14dp"
                android:paddingTop="10dp"
                android:paddingBottom="2dp">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupFilter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:chipSpacingHorizontal="6dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipSemua"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Semua"
                        style="@style/KicauFilterChip"
                        android:checked="true" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipBurung"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Burung"
                        style="@style/KicauFilterChip" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPerlengkapan"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Perlengkapan"
                        style="@style/KicauFilterChip" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPakan"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Pakan"
                        style="@style/KicauFilterChip" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipKandang"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Kandang"
                        style="@style/KicauFilterChip" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPeternak"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Peternak"
                        style="@style/KicauFilterChip" />
                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>

            <!-- Header count + sort -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp"
                android:paddingTop="10dp"
                android:paddingBottom="6dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvProdukCount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="1.240 produk"
                    android:textSize="14sp"
                    android:textColor="@color/text_dark"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/btnUrutkan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⇅ Urutkan"
                    android:textSize="11sp"
                    android:textColor="@color/text_light"
                    android:padding="4dp" />
            </LinearLayout>

            <!-- Product Grid (2 kolom) -->
            <!-- Gunakan RecyclerView dengan GridLayoutManager(context, 2) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMarketGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="14dp"
                android:paddingBottom="8dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                tools:itemCount="6"
                tools:listitem="@layout/item_burung_card" />

            <Space android:layout_width="match_parent" android:layout_height="16dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── FAB: Jual Sekarang ── -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabJual"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="80dp"
        android:text="Jual Sekarang"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        app:icon="@drawable/ic_add"
        app:iconTint="@android:color/white"
        app:backgroundTint="@color/amber"
        app:elevation="4dp"
        app:layout_anchorGravity="bottom|end" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>