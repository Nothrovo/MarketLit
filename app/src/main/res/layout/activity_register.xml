<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_white"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/sage_dark"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">
        <ImageView
            android:id="@+id/btnBackReg"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/bg_white"
            android:layout_marginEnd="16dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Buat Akun"
            android:fontFamily="@font/poppins_bold"
            android:textColor="@color/bg_white"
            android:textSize="18sp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lengkapi data diri"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@color/text_dark"
                android:textSize="20sp"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Langkah 2 dari 3 · Data akun kamu"
                android:fontFamily="@font/poppins"
                android:textColor="@color/text_light"
                android:textSize="14sp"
                android:layout_marginBottom="24dp"/>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nama Lengkap"
                app:boxBackgroundColor="@color/bg_cream"
                android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:inputType="textPersonName"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Email"
                app:boxBackgroundColor="@color/bg_cream"
                android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:inputType="textEmailAddress"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="No. HP (WhatsApp)"
                app:boxBackgroundColor="@color/bg_cream"
                android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:inputType="phone"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Password"
                app:passwordToggleEnabled="true"
                app:boxBackgroundColor="@color/bg_cream"
                android:layout_marginBottom="20dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:inputType="textPassword"/>
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Saya adalah:"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@color/text_mid"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="32dp"
                android:weightSum="3">

                <!-- Default terpilih: Background gelap, Teks Putih -->
                <TextView
                    android:id="@+id/rolePembeli"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🐦 Pembeli"
                    android:fontFamily="@font/poppins_bold"
                    android:gravity="center"
                    android:padding="12dp"
                    android:background="@color/sage_dark"
                    android:textColor="@color/bg_white"
                    android:layout_marginEnd="4dp"/>

                <TextView
                    android:id="@+id/rolePenjual"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🏪 Penjual"
                    android:fontFamily="@font/poppins_bold"
                    android:gravity="center"
                    android:padding="12dp"
                    android:background="@color/bg_cream"
                    android:textColor="@color/text_mid"
                    android:layout_marginEnd="4dp"/>

                <TextView
                    android:id="@+id/rolePeternak"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🥚 Peternak"
                    android:fontFamily="@font/poppins_bold"
                    android:gravity="center"
                    android:padding="12dp"
                    android:background="@color/bg_cream"
                    android:textColor="@color/text_mid"/>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegister"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Buat Akun"
                android:fontFamily="@font/poppins_bold"
                android:textSize="16sp"
                app:cornerRadius="12dp"
                android:backgroundTint="@color/terra_mid"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:id="@+id/tvGoToLogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sudah punya akun? Masuk di sini"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@color/text_mid"
                android:gravity="center"
                android:padding="8dp"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>