<?xml version="1.0" encoding="utf-8"?>
<!-- item_dokter_card.xml -->
<!-- 1 baris card dokter di RecyclerView tab Dokter -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeWidth="0.5dp"
    app:strokeColor="@color/border">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:gap="12dp">

        <!-- Avatar dokter -->
        <ImageView
            android:id="@+id/imgDokterAvatar"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/ic_doctor_placeholder"
            android:background="@drawable/bg_avatar_green"
            android:scaleType="centerCrop"
            android:contentDescription="Foto dokter" />

        <!-- Info dokter -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gap="2dp">

            <TextView
                android:id="@+id/tvDokterNama"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="drh. Budi Santoso"
                android:textSize="13sp"
                android:textColor="@color/text_dark"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tvDokterSpesialis"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Spesialis Kicauan · 10 thn"
                android:textSize="11sp"
                android:textColor="@color/text_light" />

            <TextView
                android:id="@+id/tvDokterRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="★★★★★ 4.9 (128)"
                android:textSize="10sp"
                android:textColor="@color/amber" />
        </LinearLayout>

        <!-- Status + Tombol -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end|center_vertical"
            android:gap="6dp">

            <!-- Status Online / Sibuk -->
            <TextView
                android:id="@+id/tvDokterStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Online"
                android:textSize="9sp"
                android:textColor="@color/green_dark"
                android:background="@drawable/bg_badge_status_online"
                android:paddingHorizontal="7dp"
                android:paddingVertical="2dp"
                android:fontFamily="sans-serif-medium" />

            <!-- Tombol Chat / Jadwal -->
            <Button
                android:id="@+id/btnDokterAksi"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Chat"
                android:textSize="10sp"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/green_dark"
                android:paddingHorizontal="12dp"
                app:cornerRadius="20dp" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>