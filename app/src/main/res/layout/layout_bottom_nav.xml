<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/bottomNav"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bg_white"
    android:elevation="8dp"
    android:orientation="horizontal"
    android:paddingVertical="8dp"
    android:weightSum="5">

    <LinearLayout android:id="@+id/navHome" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏠" android:textSize="20sp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Beranda" android:fontFamily="@font/poppins" android:textColor="@color/text_light" android:textSize="10sp"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/navLomba" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏆" android:textSize="20sp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lomba" android:fontFamily="@font/poppins" android:textColor="@color/text_light" android:textSize="10sp"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/navMarket" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🛍️" android:textSize="20sp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Market" android:fontFamily="@font/poppins" android:textColor="@color/text_light" android:textSize="10sp"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/navVet" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🩺" android:textSize="20sp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dokter" android:fontFamily="@font/poppins" android:textColor="@color/text_light" android:textSize="10sp"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/navProfil" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="👤" android:textSize="20sp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Profil" android:fontFamily="@font/poppins_bold" android:textColor="@color/sage_dark" android:textSize="10sp"/>
        <View android:layout_width="4dp" android:layout_height="4dp" android:layout_marginTop="2dp" android:background="@color/sage_dark"/>
    </LinearLayout>

</LinearLayout>